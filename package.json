{
  "name": "brreg-snap",
  "version": "1.0.1",
  "description": "Firefox-utvidelse som henter bedriftsinfo fra Brønnøysundregistrene med ett klikk.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "vite build",
    "dev": "pnpm run build && web-ext run --source-dir dist",
    "watch": "vite build --watch",
    "package": "pnpm run build && web-ext build --source-dir dist --artifacts-dir web-ext-artifacts --overwrite-dest",
    "lint:ext": "web-ext lint --source-dir dist",
    "lint:ts": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/firefox-webext-browser": "^120.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0",
    "web-ext": "^7.11.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ikkeseb/brreg-snap.git"
  },
  "license": "MIT"
}
